# DescribeX — Environment Configuration
#
# Copy this file to .env and fill in the values.
# All engine settings use the DESCRIBEX_ prefix.

# --- Provider Selection ---
# Which AI provider to use: 'fireworks' or 'gemini'
DESCRIBEX_PROVIDER=fireworks

# --- API Keys ---
DESCRIBEX_FIREWORKS_API_KEY=
DESCRIBEX_GEMINI_API_KEY=

# --- Model IDs (read from config — never hardcoded) ---
DESCRIBEX_VISION_MODEL_ID=accounts/fireworks/models/qwen2p5-vl-32b-instruct
DESCRIBEX_TEXT_MODEL_ID=accounts/fireworks/models/qwen2p5-vl-32b-instruct
DESCRIBEX_GEMINI_MODEL=gemini-2.5-flash

# --- Supabase (future) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OAuth (future) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=